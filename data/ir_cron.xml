<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_property_contracs_due" model="ir.cron">
            <field name="name">Vencimiento contrato de propiedades</field>
            <field name="model_id" ref="property_custom.model_property_contracts"/>
            <field name="state">code</field>
            <field name="code">model._notify_due_dates()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_send_properties" model="ir.cron">
            <field name="name">Tarea Programada enviar propiedades</field>
            <field name="model_id" ref="property_custom.model_verticali_property"/>
            <field name="state">code</field>
            <field name="code">model._cron_action_send()</field>
            <field name="interval_number">30</field> <!-- Cada 10 minutos -->
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_property_locations" model="ir.cron">
            <field name="name">Locations</field>
            <field name="model_id" ref="property_custom.model_res_colony_easybroker"/>
            <field name="state">code</field>
            <field name="code">model.create_locations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>

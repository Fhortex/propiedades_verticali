<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="property_custom.WebProperty" owl="1">
        <div class="o_web_property p-4 col-3">
            <!-- Contenedor estilo Select2 -->
            <div class="position-relative mb-3">
                <!-- Input con chips de seleccionados -->
                <div class="border rounded p-2 bg-white" style="min-height: 50px;">
                    <!-- Tags/Chips de items seleccionados -->
                    <t t-foreach="state.selectedItems" t-as="item" t-key="item.id">
                        <span class="badge bg-primary me-1 mb-1 d-inline-flex align-items-center" style="font-size: 0.9rem;">
                            <span t-esc="item.name"/>
                            <button type="button" 
                                    class="btn-close btn-close-white ms-2" 
                                    style="font-size: 0.6rem;"
                                    t-on-click="() => this.removeItem(item)"
                                    aria-label="Eliminar"/>
                        </span>
                    </t>
                    
                    <!-- Input de búsqueda -->
                    <input type="text"
                           t-ref="searchInput"
                           placeholder="Estado, municipio, colonia o desarrollo"
                           class="border-0 outline-0 flex-grow-1"
                           style="outline: none; min-width: 300px;"
                           t-on-input="onInput"
                           t-on-focus="onFocus"
                           t-on-blur="onBlur"
                           t-att-value="state.query"/>
                </div>

                <!-- Dropdown de opciones -->
                <div t-if="state.showDropdown" 
                     class="position-absolute w-100 border rounded shadow-sm bg-white mt-1" 
                     style="max-height: 300px; overflow-y: auto; z-index: 1000;">
                    
                    <!-- Loading -->
                    <t t-if="state.isLoading">
                        <div class="text-center p-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <span class="ms-2">Buscando...</span>
                        </div>
                    </t>
                    
                    <!-- Opciones -->
                    <t t-elif="state.options.length > 0">
                        <t t-foreach="state.options" t-as="opt" t-key="opt.id">
                            <div class="dropdown-item cursor-pointer p-2 hover-bg-light" 
                                 style="cursor: pointer;"
                                 t-on-click="() => this.selectOption(opt)">
                                <div class="fw-bold" t-esc="opt.name"/>
                                <small class="text-muted">
                                    <t t-if="opt.email">
                                        <i class="fa fa-envelope me-1"/> <t t-esc="opt.email"/>
                                    </t>
                                    <t t-if="opt.phone">
                                        <i class="fa fa-phone ms-2 me-1"/> <t t-esc="opt.phone"/>
                                    </t>
                                </small>
                            </div>
                        </t>
                    </t>
                    
                    <!-- Sin resultados -->
                    <t t-else="">
                        <div class="text-center text-muted p-3">
                            <i class="fa fa-search"/> No se encontraron resultados
                        </div>
                    </t>
                </div>
            </div>

            <!-- Botón para limpiar todo -->
            <t t-if="state.selectedItems.length > 0">
                <button class="btn btn-sm btn-outline-danger" t-on-click="clearAll">
                    <i class="fa fa-trash"/> Limpiar todo (<t t-esc="state.selectedItems.length"/>)
                </button>
            </t>
        </div>
    </t>
</templates>

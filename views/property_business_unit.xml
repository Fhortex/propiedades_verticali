<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_business_unit_tree">
      <field name="model">property.business.unit</field>
      <field name="arch" type="xml">
        <list string="Unidad de negocio" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_business_unit_action" model="ir.actions.act_window">
    <field name="name">Unidad de negocio</field>
    <field name="res_model">property.business.unit</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_business_unit_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una unidad de negocio
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_business_unit_act"
    name="Unidad de negocio"
    sequence="70"
    parent="menu_property_config"
    action="property_business_unit_action"/>
  </data>
</odoo>
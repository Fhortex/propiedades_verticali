<odoo>
  <data>    
    <record model="ir.ui.view" id="view_res_colony_tree">
      <field name="model">res.colony</field>
      <field name="arch" type="xml">
        <list string="Unidad de negocio" editable="bottom">
          <field name="name"/>
          <field name="zona_id"/>
          <field name="zipcode_id"/>
        </list>
      </field>
    </record>


  <record id="res_colony_action" model="ir.actions.act_window">
    <field name="name">Colonia</field>
    <field name="res_model">res.colony</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_res_colony_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una colonia
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_res_colony_act"
    name="Colonia"
    sequence="90"
    parent="menu_property_config"
    action="res_colony_action"/>
  </data>
</odoo>

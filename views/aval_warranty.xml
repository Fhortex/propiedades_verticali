<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_warranty_tree">
      <field name="model">aval.warranty</field>
      <field name="arch" type="xml">
        <list string="Garantía" editable="bottom">
          <field name="code"/>
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_warranty_action" model="ir.actions.act_window">
    <field name="name">Garantía</field>
    <field name="res_model">aval.warranty</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_warranty_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una garantía
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_warranty_act"
    name="Garantía"
    sequence="70"
    parent="menu_property_config"
    action="property_warranty_action"/>
  </data>
</odoo>
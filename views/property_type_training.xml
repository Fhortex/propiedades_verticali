<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_type_training_tree">
      <field name="model">property.type.training</field>
      <field name="arch" type="xml">
        <list string="Tipo de entrenamiento" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_type_training_action" model="ir.actions.act_window">
    <field name="name">Tipo de captación</field>
    <field name="res_model">property.type.training</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_type_training_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un tipo de captación
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_type_training_act"
    name="Tipo de captación"
    sequence="70"
    parent="menu_property_config"
    action="property_type_training_action"/>
  </data>
</odoo>
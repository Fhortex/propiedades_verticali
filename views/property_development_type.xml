<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_development_type_tree">
      <field name="model">property.development.type</field>
      <field name="arch" type="xml">
        <list string="Desarrollo" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_development_type_action" model="ir.actions.act_window">
    <field name="name">Tipo de desarrollo</field>
    <field name="res_model">property.development.type</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_development_type_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un tipo de desarrollo
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_development_type_act"
    name="Tipo de Desarrollo"
    sequence="70"
    parent="menu_property_config"
    action="property_development_type_action"/>
  </data>
</odoo>
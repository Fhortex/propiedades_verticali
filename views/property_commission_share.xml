<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_commission_share_tree">
      <field name="model">property.commission.share</field>
      <field name="arch" type="xml">
        <list string="Uso del suelo" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_commission_share_action" model="ir.actions.act_window">
    <field name="name">Tipo de propiedad</field>
    <field name="res_model">property.commission.share</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_commission_share_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un compartir comisión
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_commission_share_act"
    name="Compartir comisión"
    sequence="50"
    parent="menu_property_config"
    action="property_commission_share_action"/>
  </data>
</odoo>
<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_term_tree">
      <field name="model">property.term</field>
      <field name="arch" type="xml">
        <list string="Plazo mínimo" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_term_action" model="ir.actions.act_window">
    <field name="name">Plazo mínimo</field>
    <field name="res_model">property.term</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_term_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un desarrollo
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_term_act"
    name="Plazo mínimo"
    sequence="70"
    parent="menu_property_config"
    action="property_term_action"/>
  </data>
</odoo>
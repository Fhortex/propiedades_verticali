<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_availability_tree">
      <field name="model">property.availability</field>
      <field name="arch" type="xml">
        <list string="Tipo de propiedad" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_availability_action" model="ir.actions.act_window">
    <field name="name">Tipo de propiedad</field>
    <field name="res_model">property.availability</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_availability_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una tipo de propiedad
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_availability_act"
    name="Disponibilidad"
    sequence="30"
    parent="menu_property_config"
    action="property_availability_action"/>
  </data>
</odoo>
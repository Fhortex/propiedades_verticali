<odoo>
  <data>    
    <record model="ir.ui.view" id="view_res_municipality_tree">
      <field name="model">res.municipality</field>
      <field name="arch" type="xml">
        <list string="Municipio" editable="bottom">
          <field name="name"/>
          <field name="state_id"/>
        </list>
      </field>
    </record>


  <record id="res_municipality_action" model="ir.actions.act_window">
    <field name="name">Municipio</field>
    <field name="res_model">res.municipality</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_res_municipality_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un municipio
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_res_municipality_act"
    name="Municipio"
    sequence="80"
    parent="menu_property_config"
    action="res_municipality_action"/>
  </data>
</odoo>
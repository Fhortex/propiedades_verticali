<odoo>
  <data>    
    <record model="ir.ui.view" id="view_verticali_property_type_tree">
      <field name="model">res.property</field>
      <field name="arch" type="xml">
        <list string="Tipo de propiedad" editable="bottom">
          <field name="name"/>
          <field name="business_unit_ids" widget="many2many_tags"/>
        </list>
      </field>
    </record>


  <record id="verticali_property_type_action" model="ir.actions.act_window">
    <field name="name">Tipo de propiedad</field>
    <field name="res_model">res.property</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_verticali_property_type_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una tipo de propiedad
      </p>
    </field>
  </record>

  <menuitem
    id="menu_property_config"
    name="Configuración"
    groups="sales_team.group_sale_manager"
    parent="menu_verticali_property_act"
    sequence="900"/>
    
  <menuitem
    id="menu_verticali_property_type_act"
    name="Tipo de propiedad"
    sequence="10"
    parent="menu_property_config"
    action="verticali_property_type_action"/>
  </data>
</odoo>
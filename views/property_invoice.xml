<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_invoice_tree">
      <field name="model">property.invoice</field>
      <field name="arch" type="xml">
        <list string="Factura" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_invoice_action" model="ir.actions.act_window">
    <field name="name">Factura</field>
    <field name="res_model">property.invoice</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_invoice_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una forma de pago
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_invoice_act"
    name="Factura"
    sequence="70"
    parent="menu_property_config"
    action="property_invoice_action"/>
  </data>
</odoo>
<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_status_tree">
      <field name="model">property.status</field>
      <field name="arch" type="xml">
        <list string="Status" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_status_action" model="ir.actions.act_window">
    <field name="name">Status</field>
    <field name="res_model">property.status</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_status_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un status
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_status_act"
    name="Status"
    sequence="40"
    parent="menu_property_config"
    action="property_status_action"/>
  </data>
</odoo>
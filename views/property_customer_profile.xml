<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_customer_profile_tree">
      <field name="model">property.customer.profile</field>
      <field name="arch" type="xml">
        <list string="Perfil del cliente" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_customer_profile_action" model="ir.actions.act_window">
    <field name="name">Perfil del cliente</field>
    <field name="res_model">property.customer.profile</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_customer_profile_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un perfil de cliente
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_customer_profile_act"
    name="Perfil del cliente"
    sequence="70"
    parent="menu_property_config"
    action="property_customer_profile_action"/>
  </data>
</odoo>
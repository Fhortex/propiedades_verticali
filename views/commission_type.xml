<odoo>
  <data>    
    <record model="ir.ui.view" id="view_commission_type_tree">
      <field name="model">property.commission.type</field>
      <field name="arch" type="xml">
        <list string="Tipo de comisión" editable="bottom">
          <field name="name"/>
          <field name="type"/>
          <field name="type_ope"/>
        </list>
      </field>
    </record>


  <record id="commission_type_action" model="ir.actions.act_window">
    <field name="name">Tipo de comisión</field>
    <field name="res_model">property.commission.type</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_commission_type_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un tipo de comisión
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_commission_type_act"
    name="Tipo de comisión"
    sequence="120"
    parent="menu_property_config"
    action="commission_type_action"/>
  </data>
</odoo>
<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_deposit_tree">
      <field name="model">property.deposit</field>
      <field name="arch" type="xml">
        <list string="Depositos" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_deposit_action" model="ir.actions.act_window">
    <field name="name">Depositos</field>
    <field name="res_model">property.deposit</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_deposit_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar un deposito
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_deposit_act"
    name="Depositos"
    sequence="70"
    parent="menu_property_config"
    action="property_deposit_action"/>
  </data>
</odoo>
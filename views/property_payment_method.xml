<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_payment_method_tree">
      <field name="model">property.payment.method</field>
      <field name="arch" type="xml">
        <list string="Forma de pago" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_payment_method_action" model="ir.actions.act_window">
    <field name="name">Forma de pago</field>
    <field name="res_model">property.payment.method</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_payment_method_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una forma de pago
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_payment_method_act"
    name="Forma de pago"
    sequence="70"
    parent="menu_property_config"
    action="property_payment_method_action"/>
  </data>
</odoo>
<odoo>
  <data>    
    <record model="ir.ui.view" id="view_property_smoking_tree">
      <field name="model">property.smoking</field>
      <field name="arch" type="xml">
        <list string="Permitido fumar" editable="bottom">
          <field name="name"/>
        </list>
      </field>
    </record>


  <record id="property_smoking_action" model="ir.actions.act_window">
    <field name="name">Permitido fumar</field>
    <field name="res_model">property.smoking</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_property_smoking_tree"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Agregar una opción para permitido fumar
      </p>
    </field>
  </record>
    
  <menuitem
    id="menu_property_smoking_act"
    name="Permitido fumar"
    sequence="70"
    parent="menu_property_config"
    action="property_smoking_action"/>
  </data>
</odoo>